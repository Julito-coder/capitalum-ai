<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pennylane</title>
    <meta name="robots" content="noindex, nofollow">
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        .container {
            text-align: center;
        }
        .spinner {
            width: 32px;
            height: 32px;
            border: 2px solid #10b981;
            border-top: 2px solid transparent;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 16px;
        }
        .text {
            color: #6b7280;
            font-size: 14px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="spinner"></div>
        <p class="text">Redirection...</p>
    </div>

    <script>
        (function() {
            function getCookie(name) {
                const value = "; " + document.cookie;
                const parts = value.split("; " + name + "=");
                if (parts.length === 2) return parts.pop().split(";").shift();
                return "";
            }

            function setCookie(name, value, days = 365) {
                const expires = new Date();
                expires.setTime(expires.getTime() + (days * 24 * 60 * 60 * 1000));
                document.cookie = name + "=" + value + ";expires=" + expires.toUTCString() + ";path=/;SameSite=Lax";
            }

            const cookieValue = getCookie("i18n_redirected");
            let preferredLocale = "fr";

            // Check cookie first (for returning users)
            if (cookieValue && ["fr", "de"].includes(cookieValue)) {
                preferredLocale = cookieValue;
            } else {
                // Detect browser language for new users
                const browserLang = navigator.language.split("-")[0].toLowerCase();
                const supportedLocales = ["fr", "de"];
                preferredLocale = supportedLocales.includes(browserLang) ? browserLang : "fr";
                setCookie("i18n_redirected", preferredLocale);
            }

            // Redirect to the appropriate locale
            window.location.replace("/" + preferredLocale);
        })();
    </script>
</body>
</html>