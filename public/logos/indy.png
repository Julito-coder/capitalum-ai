		{
    "@context": "http://schema.org",
    "@type": "SoftwareApplication",
    "name": "Indy",
    "creator": {
        "@type": "Organization",
        "@id": "https://www.indy.fr/#organization",
        "name": "Indy",
        "url": "https://www.indy.fr/",
        "logo": {
            "@type": "ImageObject",
            "inLanguage": "fr-FR",
            "@id": "https://www.indy.fr/#/schema/logo/image/",
            "url": "https://www.indy.fr/wp-content/uploads/logo-indy-2.png",
            "contentUrl": "https://www.indy.fr/wp-content/uploads/logo-indy-2.png",
            "width": 150,
            "height": 78,
            "caption": "Indy"
        },
        "image": {
            "@id": "https://www.indy.fr/#/schema/logo/image/"
        }
    },
    "description": "Indy est une solution de comptabilit\u00e9 con\u00e7ue pour les ind\u00e9pendants, automatisant la gestion de leur activit\u00e9 et g\u00e9n\u00e9rant toutes leurs d\u00e9clarations. Avec l'accompagnement de conseillers sp\u00e9cialis\u00e9s, Indy facilite la vie professionnelle des ind\u00e9pendants.",
    "operatingSystem": "Web-based, Android, IOS",
    "applicationCategory": "accounting software",
    "sameAs": "https://indy.fr",
    "datePublished": "2016-06-01",
    "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "EUR",
        "highPrice": "49",
        "lowPrice": "0",
        "offerCount": "5",
        "offers": [
            {
                "@type": "Offer",
                "price": "0.00",
                "priceCurrency": "EUR",
                "description": "Indy, incluant synchronisation bancaire, pilotage en temps r\u00e9el, cat\u00e9gorisation intelligente des transactions, auto-d\u00e9tection de la TVA, gestion des notes de frais par photo, devis et factures personnalis\u00e9s, et un compte Pro Indy avec 1 carte virtuelle."
            },
            {
                "@type": "Offer",
                "price": "12.00",
                "priceCurrency": "EUR",
                "description": "Indy Premium pour les micro-entreprise avec ou sans TVA, offrant toutes les fonctionnalit\u00e9s de Indy Gratuit plus d\u00e9claration du CA \u00e0 l'Urssaf, d\u00e9claration de TVA, g\u00e9n\u00e9ration des documents obligatoires, aide \u00e0 la d\u00e9claration de revenus, accompagnement par des conseillers sp\u00e9cialis\u00e9s."
